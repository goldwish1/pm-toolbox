    "slug": "pert-analysis",
    "name": "PERT 分析",
    "nameEn": "PERT Analysis",
    "processGroup": "规划",
    "knowledgeArea": "时间",
    "summary": "使用三点估算技术评估项目工期的不确定性",
    "description": "PERT（计划评审技术）通过乐观时间、最可能时间和悲观时间三点估算，计算加权平均工期。公式为：(乐观 + 4×最可能 + 悲观) / 6，适用于不确定性高的项目。",
    "steps": [
      "对每个活动估算乐观时间(O)、最可能时间(M)、悲观时间(P)",
      "使用公式计算期望时间：TE = (O + 4M + P) / 6",
      "计算每个活动的标准差：SD = (P - O) / 6",
      "确定关键路径的期望工期",
      "计算项目按时完成的概率"
    ],
    "scenarios": ["工期估算", "不确定性分析", "进度风险评估"],
    "template": "活动、乐观时间、最可能时间、悲观时间、期望时间、标准差",
    "templateType": "table",
    "tableConfig": {
      "columns": [
        { "key": "activity", "label": "活动", "type": "text", "placeholder": "活动名称" },
        { "key": "optimistic", "label": "乐观时间(O)", "type": "text", "placeholder": "天数" },
        { "key": "mostLikely", "label": "最可能时间(M)", "type": "text", "placeholder": "天数" },
        { "key": "pessimistic", "label": "悲观时间(P)", "type": "text", "placeholder": "天数" },
        { "key": "expected", "label": "期望时间(TE)", "type": "text", "placeholder": "自动计算" },
        { "key": "stdDev", "label": "标准差(SD)", "type": "text", "placeholder": "自动计算" }
      ]
    }
  },
